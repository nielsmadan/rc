[alias]
    ca = commit -am
    caa = commit -a --amend --no-edit
    cm = commit -m
    ci = commit

    co = checkout
    cob = checkout -b

    ; com = checkout main or master
    com = !git switch $(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@') 2>/dev/null || git switch main 2>/dev/null || git switch master

    ; checkout "parent" branch
    cop = "!git checkout $(git log --oneline --decorate --first-parent | grep -v \"$(git branch --show-current)\" | head -1 | sed 's/.*(\\([^,)]*\\)).*/\\1/')"

    cp = cherry-pick
    cpa = cherry-pick --abort
    cpc = cherry-pick --continue

    bl = branch -l
    blso = branch --sort=-committerdate
    bd = branch -D

    s = status

    l = log --pretty=oneline --abbrev-commit
    gl = log --graph --pretty=oneline --abbrev-commit

    wta = worktree add
    wtls = worktree list
    wtrm = worktree remove
    wtp = worktree prune

    r = rebase
    rbi = rebase --interactive
    rbm = rebase main
    rbc = rebase --continue
    rba = rebase --abort

    rhom = reset --hard origin/main

    fom = fetch origin main
    pr = pull --rebase

    st = stash
    stu = stash --keep-index
    sp = stash pop

    po = push origin
    pom = push origin main
    pof = push origin -f
    puoh = push -u origin HEAD

    ; mvim difftool (default tool, see [diff] below).
    d = difftool
    d1 = difftool HEAD~1
    d2 = difftool HEAD~2
    d3 = difftool HEAD~3
    dc = difftool --cached

    ; Neovide + diffview.nvim. No args -> diffview (full repo view, detached via --fork). With args (file paths, revs) -> per-file neovide difftool (stays attached so git can clean up temp files).
    ; --chdir tells neovide which dir to launch in; --fork detaches from the terminal. Needs neovide >= 0.16.
    nd = "!f() { if [ $# -eq 0 ]; then neovide --fork --chdir \"$PWD\" -- -c DiffviewOpen; else git difftool -t neovide \"$@\"; fi; }; f"
    nd1 = "!f() { if [ $# -eq 0 ]; then neovide --fork --chdir \"$PWD\" -- -c 'DiffviewOpen HEAD~1'; else git difftool -t neovide HEAD~1 \"$@\"; fi; }; f"
    nd2 = "!f() { if [ $# -eq 0 ]; then neovide --fork --chdir \"$PWD\" -- -c 'DiffviewOpen HEAD~2'; else git difftool -t neovide HEAD~2 \"$@\"; fi; }; f"
    nd3 = "!f() { if [ $# -eq 0 ]; then neovide --fork --chdir \"$PWD\" -- -c 'DiffviewOpen HEAD~3'; else git difftool -t neovide HEAD~3 \"$@\"; fi; }; f"
    ndc = "!f() { if [ $# -eq 0 ]; then neovide --fork --chdir \"$PWD\" -- -c 'DiffviewOpen --cached'; else git difftool -t neovide --cached \"$@\"; fi; }; f"
    dns = diff --name-status
    outgoing = log origin..main

[color]
	ui = true

[core]
	editor = "mvim -f"
	excludesfile = /Users/nielsm/.gitignore
	autocrlf = false

[diff]
	tool = mvimdiff

[difftool "mvimdiff"]
	; Small sleep works around a race where consecutive `mvim -f` invocations
	; lose the GUI handoff and silently fall back to terminal vim.
	cmd = sleep 0.3 && mvim -f -d \"$LOCAL\" \"$REMOTE\"

[difftool "neovide"]
	cmd = neovide --no-fork --no-tabs \"$LOCAL\" \"$REMOTE\" -- -d

[difftool]
	prompt = false

[merge]
  defaultToUpstream = true
	tool = neovide

[mergetool "neovide"]
	cmd = neovide --no-fork --no-tabs \"$LOCAL\" \"$MERGED\" \"$REMOTE\" -- -d

[user]
	name = Niels Madan
	email = nielsmadan@quantumcraft.io

[push]
	default = simple
	autoSetupRemote = true

[include]
  path = ~/.gitconfig-local

[rerere]
	enabled = true

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process

[rebase]
	autoStash = true
