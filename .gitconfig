[alias]
    ca = commit -am
    caa = commit -a --amend --no-edit
    cm = commit -m
    ci = commit

    co = checkout
    cob = checkout -b

    ; com = checkout main or master
    com = !git switch $(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@') 2>/dev/null || git switch main 2>/dev/null || git switch master

    ; checkout "parent" branch
    cop = "!git checkout $(git log --oneline --decorate --first-parent | grep -v \"$(git branch --show-current)\" | head -1 | sed 's/.*(\\([^,)]*\\)).*/\\1/')"

    cp = cherry-pick
    cpa = cherry-pick --abort
    cpc = cherry-pick --continue

    bl = branch -l
    blso = branch --sort=-committerdate
    bd = branch -D

    s = status

    l = log --pretty=oneline --abbrev-commit
    gl = log --graph --pretty=oneline --abbrev-commit

    wta = worktree add
    wtls = worktree list
    wtrm = worktree remove
    wtp = worktree prune

    r = rebase
    ; `rbi N` -> rebase -i HEAD~N (bare number); anything else passes through (e.g. `rbi origin/main`, `rbi --root`).
    rbi = "!f() { if [ $# -eq 1 ]; then case \"$1\" in ''|*[!0-9]*) git rebase --interactive \"$@\";; *) git rebase --interactive \"HEAD~$1\";; esac; else git rebase --interactive \"$@\"; fi; }; f"
    rbm = rebase main
    rbc = rebase --continue
    rba = rebase --abort

    rhom = reset --hard origin/main
    ; `rs N` -> reset --soft HEAD~N (bare number); anything else passes through.
    rs = "!f() { if [ $# -eq 1 ]; then case \"$1\" in ''|*[!0-9]*) git reset --soft \"$@\";; *) git reset --soft \"HEAD~$1\";; esac; else git reset --soft \"$@\"; fi; }; f"
    rsu = reset --soft @{upstream}

    fom = fetch origin main
    pr = pull --rebase

    st = stash
    stu = stash --keep-index
    sp = stash pop

    po = push origin
    pom = push origin main
    pof = push origin -f
    puoh = push -u origin HEAD

    ; mvim difftool (default tool, see [diff] below). `d N` -> difftool HEAD~N (bare number); file paths/refs pass through.
    ; `cd` into GIT_PREFIX because `!` aliases run from the repo root, so relative file paths would otherwise break.
    d = "!f() { cd \"./${GIT_PREFIX:-}\" && if [ $# -eq 1 ]; then case \"$1\" in ''|*[!0-9]*) git difftool \"$@\";; *) git difftool \"HEAD~$1\";; esac; else git difftool \"$@\"; fi; }; f"
    dc = difftool --cached

    ; Neovide + diffview.nvim. No args -> diffview (full repo view, detached via --fork). `nd N` -> diffview at HEAD~N.
    ; With file paths/refs -> per-file neovide difftool (stays attached so git can clean up temp files).
    ; --chdir tells neovide which dir to launch in; --fork detaches from the terminal. Needs neovide >= 0.16.
    ; `cd` into GIT_PREFIX because `!` aliases run from the repo root, so relative file paths would otherwise break.
    nd = "!f() { cd \"./${GIT_PREFIX:-}\" && if [ $# -eq 0 ]; then neovide --fork --chdir \"$PWD\" -- -c DiffviewOpen; elif [ $# -eq 1 ]; then case \"$1\" in ''|*[!0-9]*) git difftool -t neovide \"$@\";; *) neovide --fork --chdir \"$PWD\" -- -c \"DiffviewOpen HEAD~$1\";; esac; else git difftool -t neovide \"$@\"; fi; }; f"
    ndc = "!f() { if [ $# -eq 0 ]; then neovide --fork --chdir \"$PWD\" -- -c 'DiffviewOpen --cached'; else git difftool -t neovide --cached \"$@\"; fi; }; f"
    dns = diff --name-status
    outgoing = log origin..main

[color]
	ui = true

[core]
	editor = "mvim -f"
	autocrlf = false

[diff]
	tool = mvimdiff

[difftool "mvimdiff"]
	; Small sleep works around a race where consecutive `mvim -f` invocations
	; lose the GUI handoff and silently fall back to terminal vim.
	cmd = sleep 0.3 && mvim -f -d \"$LOCAL\" \"$REMOTE\"

[difftool "neovide"]
	cmd = neovide --no-fork --no-tabs \"$LOCAL\" \"$REMOTE\" -- -d

[difftool]
	prompt = false

[merge]
  defaultToUpstream = true
	tool = neovide

[mergetool "neovide"]
	cmd = neovide --no-fork --no-tabs \"$LOCAL\" \"$MERGED\" \"$REMOTE\" -- -d

[user]
	name = Niels Madan
	email = nielsmadan@quantumcraft.io
	signingkey = /Users/nielsmadan/.ssh/id_ed25519.pub

[push]
	default = simple
	autoSetupRemote = true

[include]
  path = ~/.gitconfig-local

[rerere]
	enabled = true

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process

[rebase]
	autoStash = true
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = /Users/nielsmadan/.ssh/allowed_signers
